{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "starter-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-07",
  "services": [{ "binding": "AUTH", "service": "starter-auth" }],
  "d1_databases": [
    {
      "binding": "APP_DB",
      "database_name": "starter_app_db",
      "database_id": "local-app-db",
      "migrations_dir": "../../packages/database/drizzle/migrations"
    }
  ]
}
