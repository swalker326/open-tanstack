{
  "name": "rsbuild-tanstack-openauth-starter",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev --ui=tui --parallel --filter=@repo/auth --filter=@repo/api --filter=web",
    "type-check": "turbo run type-check",
    "check": "turbo run check",
    "check:ci": "turbo run check:ci",
    "db:generate": "pnpm --filter @repo/database exec drizzle-kit generate",
    "db:migrate:local": "pnpm --filter @repo/api exec wrangler d1 migrations apply starter_app_db --local --persist-to ../../.wrangler/state"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "turbo": "^2.8.14"
  },
  "packageManager": "pnpm@10.26.1"
}
